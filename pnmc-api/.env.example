# Azure SQL configuration for PNMC API (.NET)
AZURE_SQL_SERVER=<poner_aqui_servidor>
AZURE_SQL_DATABASE=PNMC_DB
AZURE_SQL_USER=<poner_aqui_usuario>
AZURE_SQL_PASSWORD=<poner_aqui_password>
AZURE_SQL_ENCRYPT=true
AZURE_SQL_TRUST_SERVER_CERTIFICATE=false

# Optional full connection string (takes precedence if provided)
AZURE_SQL_CONNECTION_STRING=Server=tcp:<poner_aqui_servidor>,1433;Initial Catalog=PNMC_DB;Persist Security Info=False;User ID=<poner_aqui_usuario>;Password=<poner_aqui_password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# Optional CORS override (appsettings can also be used)
# Cors__AllowedOrigins__0=http://localhost:4200

# Admin endpoints protection (header: X-Admin-Api-Key)
PNMC_ADMIN_API_KEY=<poner_aqui_admin_api_key>
