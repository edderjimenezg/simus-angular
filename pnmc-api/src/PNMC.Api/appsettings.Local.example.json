{
  "Database": {
    "EnsureSupportTables": true,
    "StartupTimeoutSeconds": 45,
    "ContinueOnStartupFailure": true
  },
  "ConnectionStrings": {
    "SqlServer": "Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<database>;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "Security": {
    "AdminApiKey": "<poner_aqui_admin_api_key>"
  }
}
